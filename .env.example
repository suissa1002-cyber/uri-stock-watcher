# ───────────────────────────────────────────────────────────────
# Stock Watcher — environment variables
# ───────────────────────────────────────────────────────────────

# Auth: random secret. Used as Bearer token on /watch, /watches, /run-check
STOCK_WATCHER_TOKEN=change-me-to-a-random-string

# Database (Postgres on Neon preferred; SQLite fallback on /data/stock_watcher.db)
# postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# NewOrder POS — read-only token (same as Ron uses)
NEWORDER_API_TOKEN=
NEWORDER_BASE_URL=https://api.neworder.co.il

# ConnectOp / ChatRace dashboard — for sending the WhatsApp template
CHATRACE_DASHBOARD_TOKEN=
CHATRACE_DASHBOARD_ACCOUNT_ID=1428408

# Cron schedule (default 09:00 Sun-Thu Israel time)
CRON_HOUR=9
CRON_DAYS=0-4
TZ=Asia/Jerusalem

# Server port (Render injects PORT automatically)
PORT=8000

# Optional: override the template name (default "new_message")
# STOCK_TEMPLATE_NAME=new_message
